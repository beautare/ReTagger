# ReTagger 环境配置模板
# 复制此文件为仓库根目录下的 .env.local 并按需修改（.env.local 不会被纳入版本控制）
# 开发构建从仓库根目录读取 .env.local；
# 发布构建由 "EmbedDotEnvLocal" 构建阶段将 .env.local 拷入 App 包内供运行时读取

# Google OAuth 2.0 Client ID（Desktop app 类型），用于“使用 Google 登录”
# 在 https://console.cloud.google.com 创建后填入；未配置时 Google 登录不可用
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com

# 开发环境后端 URL
BACKEND_URL=http://localhost:8009

# 测试环境后端 URL
STAGING_BACKEND_URL=https://proxy.retagger.vip

# 生产环境后端 URL
PRODUCTION_BACKEND_URL=https://proxy.retagger.vip

# 运行环境选择（可选，默认为 development）
# RETAGGER_ENV=development

# 其他可选配置项（可扩展）
# LOG_LEVEL=DEBUG
# ENABLE_NETWORK_MOCKING=false
# AI_PROCESSING_TIMEOUT=120
